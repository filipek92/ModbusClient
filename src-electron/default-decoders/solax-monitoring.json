{
  "id": "solax-monitoring",
  "name": "Solax Hybrid - Monitoring",
  "defaultSlaveId": 1,
  "fields": [
    {
      "address": 0,
      "type": "input",
      "name": "Grid Voltage",
      "dataType": "uint16",
      "unit": "V",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 1,
      "type": "input",
      "name": "Grid Current",
      "dataType": "int16",
      "unit": "A",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 2,
      "type": "input",
      "name": "Grid Power",
      "dataType": "int16",
      "unit": "W",
      "scale": 1,
      "precision": 0
    },
    {
      "address": 7,
      "type": "input",
      "name": "Grid Frequency",
      "dataType": "uint16",
      "unit": "Hz",
      "scale": 0.01,
      "precision": 2
    },
    {
      "address": 8,
      "type": "input",
      "name": "Inverter Temperature",
      "dataType": "int16",
      "unit": "°C",
      "scale": 1,
      "precision": 0
    },
    {
      "address": 9,
      "type": "input",
      "name": "Run Mode",
      "dataType": "uint16",
      "map": {
        "0": "Waiting",
        "1": "Checking",
        "2": "Normal",
        "3": "Fault",
        "4": "Permanent Fault"
      }
    },
    {
      "address": 3,
      "type": "input",
      "name": "PV1 Voltage",
      "dataType": "uint16",
      "unit": "V",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 4,
      "type": "input",
      "name": "PV2 Voltage",
      "dataType": "uint16",
      "unit": "V",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 5,
      "type": "input",
      "name": "PV1 Current",
      "dataType": "uint16",
      "unit": "A",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 6,
      "type": "input",
      "name": "PV2 Current",
      "dataType": "uint16",
      "unit": "A",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 10,
      "type": "input",
      "name": "Pv1 Power",
      "dataType": "uint16",
      "unit": "W",
      "scale": 1
    },
    {
      "address": 11,
      "type": "input",
      "name": "Pv2 Power",
      "dataType": "uint16",
      "unit": "W",
      "scale": 1
    },
    {
      "address": 20,
      "type": "input",
      "name": "Battery Voltage",
      "dataType": "int16",
      "unit": "V",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 21,
      "type": "input",
      "name": "Battery Current",
      "dataType": "int16",
      "unit": "A",
      "scale": 0.1,
      "precision": 1
    },
    {
      "address": 22,
      "type": "input",
      "name": "Battery Power",
      "dataType": "int16",
      "unit": "W",
      "scale": 1,
      "precision": 0,
      "transform": "return value > 0 ? 'Charging ' + value + 'W' : 'Discharging ' + Math.abs(value) + 'W';"
    },
    {
      "address": 23,
      "type": "input",
      "name": "BMS Connect State",
      "dataType": "uint16",
      "map": {
        "0": "Disconnected",
        "1": "Connected"
      }
    },
    {
      "address": 24,
      "type": "input",
      "name": "Battery Temperature",
      "dataType": "int16",
      "unit": "°C",
      "scale": 1
    },
    {
      "address": 28,
      "type": "input",
      "name": "Battery SOC",
      "dataType": "uint16",
      "unit": "%",
      "scale": 1,
      "precision": 0
    },
    {
      "address": 70,
      "type": "input",
      "name": "Feed-in Power (Total)",
      "dataType": "int32",
      "unit": "W",
      "scale": 1,
      "precision": 0,
      "wordOrder": "little-endian"
    },
    {
      "address": 148,
      "type": "input",
      "name": "Total Energy Yield",
      "dataType": "uint32",
      "unit": "kWh",
      "scale": 0.1,
      "precision": 1,
      "wordOrder": "little-endian"
    }
  ]
}
